# ============================================================
# Backend
# ============================================================
PORT=3001
JWT_SECRET=tu_secreto_aleatorio_aqui_minimo_32_caracteres

# PostgreSQL - BD desplegada en Coolify
# Copia la connection string desde el panel de tu BD en Coolify:
# Database → Connect → Connection String
DATABASE_URL=postgresql://usuario:password@host:5432/nombre_db

# Activa SSL si tu BD de Coolify lo requiere (normalmente true en producción)
DATABASE_SSL=false

# ============================================================
# Frontend (salon-dashboard-frontend/.env.local)
# ============================================================
# Desarrollo local (el backend corre en puerto 3001):
NEXT_PUBLIC_API_URL=http://localhost:3001

# En Docker/Coolify ya está configurado en docker-compose.yaml:
# NEXT_PUBLIC_API_URL=http://backend:3001
