# ============================================================
# ❗ Solo necesitas estas DOS variables de entorno en Coolify
# ============================================================

# Clave secreta para firmar los tokens JWT.
# Genera una con: openssl rand -hex 32
JWT_SECRET=cambia_esto_por_una_clave_secreta_larga_minimo_32_chars

# Contraseña interna del usuario de PostgreSQL (dentro del contenedor).
# Puedes poner cualquier cosa segura, no necesitas recordarla.
DB_PASSWORD=cambia_esto_por_una_password_segura
